# ── Rust ─────────────────────────────────────────────────────────────────────
brido_server/target/
brido_server/**/*.rs.bk

# ── Android / Gradle ─────────────────────────────────────────────────────────
brido_app/.gradle/
brido_app/local.properties
brido_app/build/
brido_app/app/build/
brido_app/.externalNativeBuild/
brido_app/.cxx/
brido_app/**/*.apk
brido_app/**/*.aab
brido_app/**/*.ap_
brido_app/**/*.dex
brido_app/captures/

# ── Android Studio / IntelliJ ────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.navigation/
*.hprof

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ───────────────────────────────────────────────────────────────────
.vscode/
*.swp
*.swo
*~

# ── Docs (selective markdown tracking) ───────────────────────────────────────
*.md
!/README.md
!/TROUBLESHOOTING.md
!/brido_app/README.md
!/brido_server/README.md
!/release_assets/server/README-server.md
*draft*.md
*scratch*.md

# ── Misc ─────────────────────────────────────────────────────────────────────
*.ico
*.png
!brido.png

# ── Security / local keys ───────────────────────────────────────────────────
*.jks
*.keystore

# ── Caches / logs ────────────────────────────────────────────────────────────
.kotlin/
*.log

# ── Secrets ──────────────────────────────────────────────────────────────────
brido_server/.env
brido_server/.env.local
brido_server/.env.local.*
!brido_server/.env.local.template

# ── Local release outputs (artifact-only) ───────────────────────────────────
release_assets/**/*.apk
release_assets/**/*.aab
release_assets/**/*.exe
release_assets/**/*.zip
release_assets/**/*.sha256

# Ignore the whole release_assets directory
/release_assets/
